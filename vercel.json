{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/residue-private",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/residue-private.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    }
  ],
  "redirects": [
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/access", "destination": "/residue-inside", "permanent": true },
    { "source": "/access.html", "destination": "/residue-inside", "permanent": true },
    { "source": "/how-it-works.html", "destination": "/how-it-works", "permanent": true },
    { "source": "/configuration.html", "destination": "/configuration", "permanent": true },
    { "source": "/drop.html", "destination": "/configuration", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/residue-inside.html", "destination": "/residue-inside", "permanent": true },
    { "source": "/residue-private.html", "destination": "/residue-private", "permanent": true }
  ]
}

